{
  "name": "VocabVault",
  "description": "Translator with Flashcard Builder",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["https://api.mymemory.translated.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  }
}