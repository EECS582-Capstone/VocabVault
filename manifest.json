{
  "name": "VocabVault",
  "description": "Translator with Flashcard Builder and transcript-driven vocab capture",
  "version": "1.1.0",
  "manifest_version": 3,
  "permissions": ["storage", "contextMenus", "tts"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["transcript-ui.js", "content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  },
  "web_accessible_resources" : [
    {
      "resources": ["styles.css"],
      "matches": ["<all_urls>"]
    }
  ] 
}
